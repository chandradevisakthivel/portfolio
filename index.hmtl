<script>
  // Cursor
  const c = document.getElementById('cursor');
  const r = document.getElementById('cursorRing');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;c.style.left=mx+'px';c.style.top=my+'px';});
  function animateRing(){rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;r.style.left=rx+'px';r.style.top=ry+'px';requestAnimationFrame(animateRing);}
  animateRing();

  // Scroll reveal
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.style.opacity='1';e.target.style.transform='translateY(0)';}});
  },{threshold:0.1});
  document.querySelectorAll('.tool-card,.proj-item,.flow-step,.about-detail-item').forEach(el=>{
    el.style.opacity='0';el.style.transform='translateY(16px)';el.style.transition='opacity 0.55s ease,transform 0.55s ease';obs.observe(el);
  });
</script>
</body>
</html>