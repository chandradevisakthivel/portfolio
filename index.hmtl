<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Chandradevi S — UI/UX Designer</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #0A0A0F;
  --bg2: #0F0F18;
  --bg3: #141420;
  --card: #12121C;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --purple: #8B5CF6;
  --purple-soft: rgba(139,92,246,0.15);
  --pink: #EC4899;
  --pink-soft: rgba(236,72,153,0.12);
  --blue: #3B82F6;
  --blue-soft: rgba(59,130,246,0.12);
  --text: #F1F0F7;
  --text-60: rgba(241,240,247,0.6);
  --text-30: rgba(241,240,247,0.3);
  --text-10: rgba(241,240,247,0.1);
  --grad: linear-gradient(135deg, var(--purple), var(--pink));
  --grad2: linear-gradient(135deg, var(--blue), var(--purple));
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-weight:300;line-height:1.6;overflow-x:hidden;}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--purple);border-radius:2px;}

/* CURSOR */
.cursor{width:8px;height:8px;background:var(--purple);border-radius:50%;position:fixed;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform 0.08s;}
.cursor-ring{width:28px;height:28px;border:1px solid rgba(139,92,246,0.4);border-radius:50%;position:fixed;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:all 0.15s ease;}

/* NOISE */
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");pointer-events:none;z-index:1000;opacity:0.5;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:500;display:flex;justify-content:space-between;align-items:center;padding:1.25rem 3rem;background:rgba(10,10,15,0.8);backdrop-filter:blur(16px);border-bottom:0.5px solid var(--border);}
.nav-logo{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;letter-spacing:0.02em;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.nav-links{display:flex;gap:2rem;align-items:center;}
.nav-links a{font-size:0.75rem;font-weight:400;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-60);text-decoration:none;transition:color 0.2s;}
.nav-links a:hover{color:var(--purple);}
.nav-hire{font-size:0.72rem;font-weight:500;letter-spacing:0.08em;padding:0.5rem 1.25rem;background:var(--grad);border-radius:100px;color:white !important;transition:opacity 0.2s;}
.nav-hire:hover{opacity:0.85;}

/* GLOW ORBS */
.orb{position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none;}
.orb1{width:500px;height:500px;background:rgba(139,92,246,0.12);top:-100px;right:-100px;}
.orb2{width:400px;height:400px;background:rgba(236,72,153,0.08);bottom:-50px;left:-80px;}
.orb3{width:300px;height:300px;background:rgba(59,130,246,0.1);top:40%;left:30%;}

/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:8rem 3rem 5rem;gap:4rem;position:relative;overflow:hidden;}

.hero-left{position:relative;z-index:1;}
.hero-badge{display:inline-flex;align-items:center;gap:0.5rem;padding:0.4rem 1rem;background:var(--purple-soft);border:0.5px solid rgba(139,92,246,0.3);border-radius:100px;margin-bottom:2rem;opacity:0;animation:fadeUp 0.7s 0.1s forwards;}
.badge-dot{width:6px;height:6px;background:#3DAA7A;border-radius:50%;animation:pulse 2s infinite;}
.badge-text{font-size:0.7rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--purple);}
.hero h1{font-family:'Syne',sans-serif;font-size:clamp(2.8rem,4.5vw,4.8rem);font-weight:800;line-height:1.05;letter-spacing:-0.03em;margin-bottom:1.5rem;opacity:0;animation:fadeUp 0.7s 0.25s forwards;}
.h1-plain{color:var(--text);}
.h1-grad{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.h1-blue{background:var(--grad2);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.hero-desc{font-size:0.92rem;color:var(--text-60);line-height:1.85;max-width:440px;margin-bottom:2.5rem;opacity:0;animation:fadeUp 0.7s 0.4s forwards;}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:fadeUp 0.7s 0.55s forwards;}
.btn-grad{display:inline-block;font-size:0.75rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;padding:0.85rem 2rem;background:var(--grad);color:white;border-radius:100px;text-decoration:none;transition:opacity 0.2s,transform 0.2s;}
.btn-grad:hover{opacity:0.85;transform:translateY(-1px);}
.btn-outline{display:inline-block;font-size:0.75rem;font-weight:400;letter-spacing:0.08em;text-transform:uppercase;padding:0.85rem 2rem;background:transparent;color:var(--text);border:0.5px solid var(--border2);border-radius:100px;text-decoration:none;transition:all 0.2s;}
.btn-outline:hover{border-color:var(--purple);color:var(--purple);}

/* HERO PHOTO SIDE */
.hero-right{position:relative;z-index:1;display:flex;justify-content:center;align-items:center;opacity:0;animation:fadeIn 1s 0.5s forwards;}
.photo-frame{position:relative;width:320px;}
.photo-glow{position:absolute;inset:-20px;background:radial-gradient(ellipse at 50% 50%, rgba(139,92,246,0.25), transparent 70%);border-radius:50%;z-index:0;}
.photo-border{position:relative;z-index:1;border-radius:24px;overflow:hidden;border:1.5px solid rgba(139,92,246,0.3);box-shadow:0 0 60px rgba(139,92,246,0.15),0 0 120px rgba(236,72,153,0.08);}
.photo-border img{width:100%;height:400px;object-fit:cover;object-position:center top;display:block;filter:saturate(0.9) contrast(1.05);}
/* Purple-tinted overlay on photo */
.photo-border::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom, transparent 60%, rgba(139,92,246,0.15) 100%);pointer-events:none;}

.photo-tag{position:absolute;bottom:-1rem;left:50%;transform:translateX(-50%);background:var(--card);border:0.5px solid var(--border2);border-radius:100px;padding:0.6rem 1.25rem;display:flex;align-items:center;gap:0.5rem;white-space:nowrap;box-shadow:0 8px 32px rgba(0,0,0,0.4);}
.pt-dot{width:7px;height:7px;background:#3DAA7A;border-radius:50%;animation:pulse 2s infinite;}
.pt-text{font-size:0.72rem;font-weight:500;color:var(--text-60);}
.pt-text strong{color:var(--text);}

/* FLOATING STAT CARDS */
.float-card{position:absolute;background:var(--card);border:0.5px solid var(--border2);border-radius:12px;padding:0.85rem 1rem;box-shadow:0 8px 32px rgba(0,0,0,0.4);}
.fc1{top:1rem;right:-2.5rem;}
.fc1-num{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:700;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.fc1-label{font-size:0.65rem;color:var(--text-30);letter-spacing:0.05em;}
.fc2{bottom:4rem;left:-2rem;}
.fc2-label{font-size:0.65rem;color:var(--text-30);margin-bottom:0.25rem;}
.fc2-val{font-size:0.8rem;font-weight:500;color:var(--purple);}

/* SECTION WRAP */
.section-wrap{padding:6rem 3rem;position:relative;overflow:hidden;}
.section-wrap.dark{background:var(--bg2);}
.section-label{display:flex;align-items:center;gap:1rem;margin-bottom:4rem;}
.sl-num{font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--purple);opacity:0.5;}
.sl-title{font-family:'Syne',sans-serif;font-size:2.5rem;font-weight:700;letter-spacing:-0.02em;color:var(--text);}
.sl-line{flex:1;height:0.5px;background:var(--border);margin-left:1rem;}

/* TOOLS SECTION */
.tools-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:1rem;}
.tool-card{background:var(--card);border:0.5px solid var(--border);border-radius:12px;padding:1.25rem;display:flex;flex-direction:column;align-items:center;gap:0.65rem;transition:all 0.25s;cursor:default;}
.tool-card:hover{border-color:var(--purple);transform:translateY(-3px);background:rgba(139,92,246,0.08);}
.tool-icon{width:40px;height:40px;display:flex;align-items:center;justify-content:center;}
.tool-name{font-size:0.75rem;font-weight:500;color:var(--text-60);text-align:center;}

/* SVG TOOL ICONS */
.icon-figma rect,.icon-figma path,.icon-figma circle{transition:0.3s;}

/* PROJECTS */
.projects-list{display:flex;flex-direction:column;gap:1.5px;background:var(--border);}
.proj-item{background:var(--bg);padding:2.5rem 3rem;display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:start;transition:background 0.25s;position:relative;overflow:hidden;}
.proj-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--grad);transform:scaleY(0);transition:transform 0.3s;transform-origin:bottom;}
.proj-item:hover{background:var(--bg2);}
.proj-item:hover::before{transform:scaleY(1);}
.proj-number{font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--text-30);margin-bottom:0.75rem;}
.proj-tags{display:flex;gap:0.5rem;margin-bottom:0.75rem;flex-wrap:wrap;}
.ptag{font-size:0.65rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;padding:0.25rem 0.65rem;border-radius:100px;border:0.5px solid;}
.ptag-purple{background:var(--purple-soft);border-color:rgba(139,92,246,0.3);color:var(--purple);}
.ptag-pink{background:var(--pink-soft);border-color:rgba(236,72,153,0.3);color:var(--pink);}
.ptag-blue{background:var(--blue-soft);border-color:rgba(59,130,246,0.3);color:var(--blue);}
.proj-title{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:700;color:var(--text);margin-bottom:0.75rem;line-height:1.2;}
.proj-desc{font-size:0.87rem;color:var(--text-60);line-height:1.85;max-width:500px;margin-bottom:1.5rem;}
.proj-link{display:inline-flex;align-items:center;gap:0.5rem;font-size:0.75rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--purple);text-decoration:none;padding:0.55rem 1.1rem;border:0.5px solid rgba(139,92,246,0.3);border-radius:100px;transition:all 0.2s;}
.proj-link:hover{background:var(--purple-soft);}
.proj-right{display:flex;flex-direction:column;align-items:flex-end;gap:1rem;}
.proj-stat{text-align:right;}
.ps-num{font-family:'Syne',sans-serif;font-size:2rem;font-weight:700;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.ps-label{font-size:0.65rem;color:var(--text-30);letter-spacing:0.05em;}

/* USER FLOW */
.flow-section{padding:6rem 3rem;background:var(--bg3);overflow:hidden;}
.flow-scroll{display:flex;gap:1rem;overflow-x:auto;padding-bottom:1rem;scrollbar-width:thin;scrollbar-color:var(--purple) transparent;}
.flow-scroll::-webkit-scrollbar{height:3px;}
.flow-scroll::-webkit-scrollbar-thumb{background:var(--purple);border-radius:2px;}
.flow-step{flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:0.5rem;}
.flow-arrow{color:var(--text-30);font-size:1.2rem;margin-top:1.5rem;flex-shrink:0;}
.flow-screen{width:120px;height:220px;background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;padding:10px 8px;display:flex;flex-direction:column;gap:5px;position:relative;transition:border-color 0.2s,transform 0.2s;}
.flow-screen:hover{border-color:var(--purple);transform:translateY(-4px);}
.fs-notch{width:30px;height:5px;background:var(--bg3);border-radius:10px;margin:0 auto 6px;}
.fs-bar{height:5px;border-radius:3px;background:rgba(139,92,246,0.25);}
.fs-bar.pk{background:rgba(236,72,153,0.25);}
.fs-bar.bl{background:rgba(59,130,246,0.25);}
.fs-bar.w40{width:40%;}
.fs-bar.w60{width:60%;}
.fs-bar.w80{width:80%;}
.fs-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:2px;}
.fs-sq{height:28px;border-radius:5px;background:rgba(139,92,246,0.1);}
.fs-sq.pk{background:rgba(236,72,153,0.1);}
.fs-big{height:50px;border-radius:5px;background:rgba(139,92,246,0.08);margin-top:2px;}
.fs-btn{height:20px;border-radius:100px;background:linear-gradient(135deg,rgba(139,92,246,0.5),rgba(236,72,153,0.5));margin-top:auto;}
.fs-label{font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:var(--text-30);text-align:center;margin-top:4px;}

/* DEVICE PREVIEW */
.preview-section{padding:6rem 3rem;background:var(--bg);}
.preview-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;}
.preview-label{font-size:0.65rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-30);margin-bottom:0.5rem;}
.preview-title{font-family:'Syne',sans-serif;font-size:1.8rem;font-weight:700;color:var(--text);margin-bottom:1rem;}
.preview-desc{font-size:0.87rem;color:var(--text-60);line-height:1.85;}

/* DESKTOP MOCKUP */
.desktop-mockup{background:var(--card);border-radius:12px;border:0.5px solid var(--border2);overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,0.5);}
.dm-bar{background:#1A1A28;padding:8px 12px;display:flex;align-items:center;gap:6px;}
.dm-dot{width:8px;height:8px;border-radius:50%;}
.dm-body{padding:12px;background:#0A0A14;min-height:160px;display:flex;flex-direction:column;gap:6px;}
.dm-row{display:grid;grid-template-columns:1fr 2fr;gap:6px;}
.dm-sidebar{background:rgba(139,92,246,0.05);border-radius:6px;border:0.5px solid var(--border);min-height:120px;padding:8px;display:flex;flex-direction:column;gap:5px;}
.dm-content{background:rgba(59,130,246,0.03);border-radius:6px;border:0.5px solid var(--border);padding:8px;display:flex;flex-direction:column;gap:5px;}
.dm-line{height:5px;border-radius:3px;}
.dm-cards{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px;margin-top:4px;}
.dm-card{height:40px;border-radius:5px;background:rgba(139,92,246,0.08);border:0.5px solid var(--border);}

/* MOBILE MOCKUP */
.mobile-mockup{width:160px;margin:0 auto;background:var(--card);border-radius:28px;border:1.5px solid rgba(139,92,246,0.2);overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,0.5);}
.mm-bar{height:24px;background:#1A1A28;display:flex;align-items:center;justify-content:center;}
.mm-notch{width:50px;height:5px;background:#0A0A14;border-radius:10px;}
.mm-body{padding:10px;background:#0A0A14;min-height:200px;display:flex;flex-direction:column;gap:5px;}

/* ABOUT */
.about-section{padding:6rem 3rem;background:var(--bg2);}
.about-grid{display:grid;grid-template-columns:auto 1fr;gap:4rem;align-items:start;}
.about-photo-col{display:flex;flex-direction:column;gap:1.5rem;}
.about-photo{width:220px;border-radius:16px;overflow:hidden;border:1.5px solid var(--border2);box-shadow:0 0 40px rgba(139,92,246,0.12);}
.about-photo img{width:100%;height:260px;object-fit:cover;object-position:center top;display:block;filter:saturate(0.85) contrast(1.05);}
/* Purple wash on about photo */
.about-photo-inner{position:relative;}
.about-photo-inner::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(139,92,246,0.08),rgba(236,72,153,0.05));pointer-events:none;}
.about-contact-mini{background:var(--card);border:0.5px solid var(--border);border-radius:12px;padding:1rem;}
.acm-label{font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-30);margin-bottom:0.5rem;}
.acm-val{font-size:0.78rem;color:var(--text-60);margin-bottom:0.35rem;}
.about-text h2{font-family:'Syne',sans-serif;font-size:2rem;font-weight:700;color:var(--text);line-height:1.3;margin-bottom:1rem;}
.about-text h2 span{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.about-text p{font-size:0.9rem;color:var(--text-60);line-height:1.9;margin-bottom:0.85rem;}
.about-skills{margin-top:2rem;display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
.as-group-label{font-size:0.65rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-30);margin-bottom:0.65rem;padding-bottom:0.5rem;border-bottom:0.5px solid var(--border);}
.as-chips{display:flex;flex-wrap:wrap;gap:0.4rem;}
.as-chip{font-size:0.72rem;padding:0.3rem 0.75rem;background:rgba(255,255,255,0.04);border:0.5px solid var(--border);border-radius:100px;color:var(--text-60);transition:all 0.2s;}
.as-chip:hover{border-color:var(--purple);color:var(--purple);}

/* CONTACT */
.contact-section{padding:6rem 3rem;background:var(--bg);position:relative;overflow:hidden;}
.contact-bg-text{position:absolute;font-family:'Syne',sans-serif;font-size:15vw;font-weight:800;color:rgba(139,92,246,0.04);bottom:-2rem;left:-1rem;white-space:nowrap;pointer-events:none;line-height:1;}
.contact-inner{position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;}
.ci-left h2{font-family:'Syne',sans-serif;font-size:3rem;font-weight:800;line-height:1.1;margin-bottom:1rem;}
.ci-left h2 .grad{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.ci-left p{font-size:0.9rem;color:var(--text-60);line-height:1.85;}
.contact-links{display:flex;flex-direction:column;gap:0.75rem;}
.cl-item{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;background:var(--card);border:0.5px solid var(--border);border-radius:10px;text-decoration:none;color:var(--text);transition:all 0.2s;cursor:pointer;}
.cl-item:hover{border-color:var(--purple);background:var(--purple-soft);}
.cl-left-text{display:flex;flex-direction:column;}
.cl-sublabel{font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-30);margin-bottom:0.2rem;}
.cl-val{font-size:0.85rem;font-weight:400;color:var(--text-60);}
.cl-item:hover .cl-val{color:var(--purple);}

/* FOOTER */
footer{background:var(--bg2);border-top:0.5px solid var(--border);padding:1.75rem 3rem;display:flex;justify-content:space-between;align-items:center;}
footer span{font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--text-30);}
.footer-grad{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-weight:500;}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(0.8);}}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}

.photo-frame{animation:float 6s ease-in-out infinite;}

/* MOBILE */
@media(max-width:768px){
  nav{padding:1rem 1.5rem;}
  .nav-links a:not(.nav-hire){display:none;}
  .hero{grid-template-columns:1fr;padding:7rem 1.5rem 4rem;gap:2rem;}
  .hero-right{display:none;}
  .section-wrap,.flow-section,.preview-section,.about-section,.contact-section{padding:4rem 1.5rem;}
  .projects-list .proj-item{padding:2rem 1.5rem;grid-template-columns:1fr;}
  .proj-right{display:none;}
  .about-grid{grid-template-columns:1fr;}
  .about-photo-col{flex-direction:row;gap:1rem;align-items:start;}
  .about-photo{width:140px;}
  .about-photo img{height:170px;}
  .contact-inner{grid-template-columns:1fr;}
  .preview-grid{grid-template-columns:1fr;}
  footer{flex-direction:column;gap:0.75rem;padding:1.5rem;}
}
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav>
  <div class="nav-logo">Chandradevi.S</div>
  <div class="nav-links">
    <a href="#work">Work</a>
    <a href="#flow">Process</a>
    <a href="#about">About</a>
    <a href="#contact" class="nav-hire">Hire me →</a>
  </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->
<div class="hero">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>

  <div class="hero-left">
    <div class="hero-badge">
      <div class="badge-dot"></div>
      <span class="badge-text">Open to freelance · Remote worldwide</span>
